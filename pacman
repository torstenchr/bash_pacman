## How does this game work?
# GAME-LOOP
#  - check for keyboard input
#  - update user
#  - update ghosts
#  - paint to screen
# REPEAT

## GLOBALS
# Base dir for the game
SCRIPT_DIR="$(dirname ${BASH_SOURCE[0]})"

# Game loop variables
FRAME_TIMER=0
FRAME_UPDATE_INTERVAL=125  # Move every 0.XXX seconds
FRAME_UPDATE_INTERVAL_US=$(( FRAME_UPDATE_INTERVAL * 1000 ))

RUNNING=1
DEBUG=
DEBUG_FLAGS=()
SCORE=0

source "$SCRIPT_DIR/lib/keyboard"
source "$SCRIPT_DIR/lib/map"
source "$SCRIPT_DIR/lib/statusbar"
source "$SCRIPT_DIR/lib/timer"
source "$SCRIPT_DIR/lib/ghosts"
source "$SCRIPT_DIR/lib/pacman"

game::setup() {
	screen::erase-all
	screen::hide-cursor
	statusbar::setup
	pacman::init

	keyboard::register-keys "game::_speed-callback" "+" "-"
	keyboard::register-keys "game::_keyboard_callback" "key-home" "key-end" "1" "2" "3" "4" "5" "6" "7" "8" "9"

	keyboard::init
	echo "" > pacman.log
}

game::_speed-callback() {
	local key="$1"

	log "key: $key"

	case $key in
		"+") (( FRAME_UPDATE_INTERVAL-=10 ));; # Speed up movement by giving more frequent updates
		"-") (( FRAME_UPDATE_INTERVAL+=10 ));; # Slow down movement by giving less frequent updates
	esac
	FRAME_UPDATE_INTERVAL_US=$(( FRAME_UPDATE_INTERVAL * 1000 ))
}

game::_keyboard_callback() {
	local key="$1"

	case $key in
		"key-home")
			game::toggle-debug
			;;
		"key-end")
			unset RUNNING
			;;
		[1-9])
			[[ -z ${DEBUG_FLAGS[$key]} ]] && DEBUG_FLAGS["$key"]="1" || DEBUG_FLAGS["$key"]=""
			;;
	esac	
}

game::teardown() {
	screen::show-cursor
}

game::toggle-debug() {
    [[ -z $DEBUG ]] && DEBUG=1 || unset DEBUG

	# Toggle FPS debugging
	timer::debug
}

game::update-keyboard() {
	# Poke the keyboard handler
	keyboard::check-for-input
}

game::update-frame() {
	## Measure time since last move, only move every FRAME_UPDATE_INTERVAL_US microsecs
	local frame_time
	frame_time=$(timer::get-elapse-time)
	FRAME_TIMER=$(( FRAME_TIMER + frame_time ))

	# No movement yet - exit the function
	[[ $FRAME_TIMER -lt $FRAME_UPDATE_INTERVAL_US ]] && return

	# Reset elapse timer
	FRAME_TIMER=0

	# Game updates on every move
	pacman::update
	ghosts::update
}

game::update-screen() {
	screen::pos-home
	map::print-map
}

game::update-statusbar() {
	local fps=$(timer::get-fps)
	local clock
	printf -v clock '%(%Y-%m-%d %H:%M:%S)T\n' -1

	local content="Score: $SCORE"
	[[ -n $DEBUG ]] && [[ -n ${DEBUG_FLAGS[1]} ]] && content="$content | Avg. FPS: $fps"
	[[ -n $DEBUG ]] && [[ -n ${DEBUG_FLAGS[2]} ]] && content="$content | Direction: $PACMAN_DIRECTION"
	[[ -n $DEBUG ]] && [[ -n ${DEBUG_FLAGS[3]} ]] && content="$content | Cheese count: $__MAP_CHEESE_COUNT"
	[[ -n $DEBUG ]] && [[ -n ${DEBUG_FLAGS[4]} ]] && content="$content | POS: ${__PACMAN_POS[0]},${__PACMAN_POS[1]}"
	[[ -n $DEBUG ]] && [[ -n ${DEBUG_FLAGS[5]} ]] && content="$content | Cell Content: $(map::get-cell-type ${__PACMAN_POS[0]} ${__PACMAN_POS[1]})"
	[[ -n $DEBUG ]] && [[ -n ${DEBUG_FLAGS[6]} ]] && content="$content | Update Time: $FRAME_UPDATE_INTERVAL"

	statusbar::update "$content"
}

main() {
	game::setup

	# Read in only map I have for now
	map::read "$SCRIPT_DIR/maps/map1"

	# GAME LOOP
	local i=0
	timer::start

	# Game loop continues until RUNNING is set!
	while [[ -n $RUNNING ]]; do
		# Input update
		game::update-keyboard

		# Game update
		game::update-frame

		# Output update
		game::update-screen

		# Update user friend statusbar
		game::update-statusbar

		# Game done?
		map::is-clear && RUNNING=""

		timer::tick

		# Frame count
		((i=i+1))
	done;

	# total time is recorded in number of microseconds since timer started
	local total_time=$(timer::stop)
	local fps=$(( (i * 1000 * 1000) / total_time ))
	screen::pos-at 0 32
	echo "Total Frames: $i | Total Time: ${total_time}us | Avg. FPS: $fps"

	game::teardown
}

main
